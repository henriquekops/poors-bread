# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# .streamlit/secrets.toml NÃO é versionado (está no .gitignore).
# No Streamlit Cloud, configure os mesmos valores em Settings > Secrets.

[github]
# Personal Access Token (fine-grained), restrito a este repositório,
# com permissão Contents: Read and write.
token  = "github_pat_..."
owner  = "henriquekops"
repo   = "poors-bread"
branch = "main"

[upload]
# Senha que protege o botão "Adicionar dados (LEM)" no dashboard.
password = "troque-esta-senha"
